# ── SafeEdge backend environment ──────────────────────────────────────────────
# Copy to backend/.env for local dev (gitignored). On Function Compute, set
# these as environment variables in the FC function configuration.

# Qwen / DashScope (Alibaba Cloud model service) — REQUIRED
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# International endpoint is the default in code. Uncomment to override (e.g. mainland China):
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Qwen model selection (verified available on intl endpoint 2026-06-30)
QWEN_REASONING_MODEL=qwen-max       # Policy Manager + Risk Forecaster (JSON)
QWEN_VISION_MODEL=qwen-vl-max       # Incident Reporter (multimodal)
QWEN_TEXT_MODEL=qwen-turbo          # Incident Reporter text-only fallback

# Location label used in incident reports
LOCATION_LABEL=Car Park

# Risk forecaster cadence (seconds)
FORECAST_INTERVAL_S=3600

# ── Tablestore (Alibaba Cloud) — OMIT for local dev (uses in-memory store) ─────
# When these are set, the backend uses Tablestore instead of in-memory.
# TABLESTORE_ENDPOINT=https://<instance>.<region>.ots.aliyuncs.com
# TABLESTORE_INSTANCE=safeedge
# ALIBABA_CLOUD_ACCESS_KEY_ID=LTAI................
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=........................

LOG_LEVEL=INFO
