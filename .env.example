# Qwen Cloud (DashScope) — get from https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Edge device identity
DEVICE_ID=safeEdge-carpark-01
LOCATION_LABEL="Car Park - North Entrance"

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET=change-me-in-prod

# Logging
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
EVENT_LOG_PATH=./logs/events.jsonl

# Cloud reporting (set false for offline-only mode)
CLOUD_REPORTING_ENABLED=true
CLOUD_REPORT_INTERVAL_S=300
